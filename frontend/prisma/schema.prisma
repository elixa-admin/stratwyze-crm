generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id            String          @id @default(cuid())
  name          String
  website       String?
  industry      String?
  employees     Int?
  annualRevenue Float?
  headquarters  String?
  legalEntity   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deals         Deal[]
  contacts      Contact[]
  templates     DealTemplate[]
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  value             Float
  currency          String     @default("ZAR")
  stage             String     @default("Prospecting")
  notes             String?
  archived          Boolean    @default(false)
  accountId         String?
  account           Account?   @relation(fields: [accountId], references: [id])
  primaryContactId  String?
  primaryContact    Contact?   @relation(fields: [primaryContactId], references: [id])
  incumbentPlatform String?
  incumbentProvider String?
  enrichmentData    Json?
  activities        Activity[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  title     String?
  role      String?
  deals     Deal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DealTemplate {
  id                   String   @id @default(cuid())
  name                 String
  accountId            String?
  account              Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  incumbentPlatform    String?
  incumbentProvider    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
