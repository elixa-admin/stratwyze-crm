generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id            String          @id @default(cuid())
  name          String
  website       String?
  industry      String?
  employees     Int?
  annualRevenue Float?
  headquarters  String?
  legalEntity   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deals         Deal[]
  contacts      Contact[]
  templates     DealTemplate[]
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  value             Float
  currency          String     @default("ZAR")
  stage             String     @default("Prospecting")
  notes             String?
  archived          Boolean    @default(false)
  dueDate           DateTime?
  nextAction        String?
  source            String?
  closureReason     String?
  lossReason        String?
  accountId         String?
  account           Account?   @relation(fields: [accountId], references: [id])
  primaryContactId  String?
  primaryContact    Contact?   @relation(fields: [primaryContactId], references: [id])
  incumbentPlatform String?
  incumbentProvider String?
  enrichmentData    Json?
  competitiveBrief  Json?
  activities        Activity[]
  stageWorkflow     DealStageWorkflow?
  opportunityProfile OpportunityProfile?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  title     String?
  role      String?
  deals     Deal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DealTemplate {
  id                   String   @id @default(cuid())
  name                 String
  accountId            String?
  account              Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  incumbentPlatform    String?
  incumbentProvider    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model DealStageWorkflow {
  id                   String   @id @default(cuid())
  dealId               String   @unique
  deal                 Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stage                String   @default("Prospecting")

  // Stage completion tracking
  stepsCompleted       String[] @default([])
  gatesMetAt           DateTime?
  completedAt          DateTime?
  completedBy          String?

  // Qualification data (filled during Qualification stage)
  incumbentPlatform    String?
  budgetRange          String?
  timeline             String?
  painPoints           String[] @default([])
  champion             String?
  fitScore             Int?
  goNoGo              String?
  positioningAngle     String?

  // Proposal data (filled during Proposal stage)
  solutionDesign       Json?
  proposalGenerated    DateTime?
  proposalData         Json?
  negotiationBrief     Json?
  proposalSentAt       DateTime?

  // Outcome
  wonAt                DateTime?
  lostAt               DateTime?
  lossReason           String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model OpportunityProfile {
  id                   String   @id @default(cuid())
  dealId               String   @unique
  deal                 Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // Aggregated intel from all stages
  companyIntel         Json?
  discoveryData        Json?
  qualificationData    Json?
  proposalData         Json?

  // Stage completion dates
  prospectingCompletedAt DateTime?
  qualificationCompletedAt DateTime?
  proposalCompletedAt DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
