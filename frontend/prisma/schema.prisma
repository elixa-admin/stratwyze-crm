generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String          @id @default(cuid())
  name               String
  website            String?
  phone              String?
  industry           String?
  employees          Int?
  annualRevenue      Float?
  headquarters       String?
  legalEntity        String?
  description        String?
  enrichmentData     Json?
  jseTickerSymbol    String?
  isListed           Boolean   @default(false)
  lastMarketDataAt   DateTime?
  marketData         Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deals              Deal[]
  contacts           Contact[]
  templates          DealTemplate[]
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  value             Float
  currency          String     @default("ZAR")
  stage             String     @default("Prospecting")
  notes             String?
  archived          Boolean    @default(false)
  dueDate           DateTime?
  nextAction        String?
  source            String?
  closureReason     String?
  lossReason        String?
  accountId         String?
  account           Account?   @relation(fields: [accountId], references: [id])
  primaryContactId  String?
  primaryContact    Contact?   @relation(fields: [primaryContactId], references: [id])
  incumbentPlatform String?
  incumbentProvider String?
  enrichmentData    Json?
  competitiveBrief  Json?
  activities        Activity[]
  stageWorkflow     DealStageWorkflow?
  opportunityProfile OpportunityProfile?
  proposals         Proposal[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model Activity {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  type      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Contact {
  id                        String    @id @default(cuid())
  accountId                 String
  account                   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name                      String
  email                     String?
  phone                     String?
  title                     String?
  role                      String?
  linkedin                  String?
  location                  String?
  department                String?
  intelligenceData          Json?
  lastResearchedAt          DateTime?
  intelligenceProfile       ContactIntelligenceProfile?
  deals                     Deal[]
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
}

model ContactIntelligenceProfile {
  id                       String    @id @default(cuid())
  contactId                String    @unique
  contact                  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  researchStartedAt        DateTime?
  researchCompletedAt      DateTime?
  researchStatus           String    @default("pending")
  researchError            String?
  nextRefreshAt            DateTime?

  companyDomain            String?
  domainConfidence         Int?
  domainSource             String?

  companyResearchData      Json?
  webResearchData          Json?

  emailCandidates          Json?
  primaryEmail             String?
  emailConfidence          Int?

  careerSummary            Json?

  decisionMakerScore       Int?
  influenceScore           Int?
  technicalInfluence       Int?
  commercialInfluence      Int?
  haloItsmRelevance        Int?
  buyingRelevance          Int?
  confidenceScore          Int?

  briefing                 Json?
  evidenceIndex            Json?

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  evidence                 ContactIntelligenceEvidence[]

  @@index([contactId])
  @@index([researchStatus])
}

model ContactIntelligenceEvidence {
  id                 String    @id @default(cuid())
  profileId          String
  profile            ContactIntelligenceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  evidenceType       String
  category           String

  factType           String?
  factValue          String?

  inferenceType      String?
  inference          String?
  reasoning          String?
  confidenceLevel    String?

  sourceUrl          String?
  sourceTitle        String?
  sourcePlatform     String?
  sourceContent      String?
  sourceCrawlDate    DateTime?
  sourceRelevance    String?

  researchStep       Int?
  dataExtractedAt    DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([profileId])
  @@index([category])
}

model DealTemplate {
  id                   String   @id @default(cuid())
  name                 String
  accountId            String?
  account              Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  incumbentPlatform    String?
  incumbentProvider    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model DealStageWorkflow {
  id                   String   @id @default(cuid())
  dealId               String   @unique
  deal                 Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stage                String   @default("Prospecting")

  // Stage completion tracking
  stepsCompleted       String[] @default([])
  gatesMetAt           DateTime?
  completedAt          DateTime?
  completedBy          String?

  // Qualification data (filled during Qualification stage)
  incumbentPlatform    String?
  budgetRange          String?
  timeline             String?
  painPoints           String[] @default([])
  champion             String?
  fitScore             Int?
  goNoGo              String?
  positioningAngle     String?

  // Solutioning data (Stage 03 — between Qualification and Proposal)
  solutioningData      Json?
  proposalReadinessScore Int?

  // Proposal data (filled during Proposal stage)
  solutionDesign       Json?
  proposalGenerated    DateTime?
  proposalData         Json?
  negotiationBrief     Json?
  proposalSentAt       DateTime?

  // Outcome + transition
  wonAt                DateTime?
  lostAt               DateTime?
  lossReason           String?
  competitorWon        String?
  lessonsLearned       String?
  handoverNotes        String?
  expansionPotential   String?

  // Stage history audit trail — array of {stage, enteredAt, exitedAt, durationDays}
  stageHistory         Json?

  // Buyer intent score (composite of market health + signals)
  buyerIntentScore     Int?
  buyerIntentSignals   String[] @default([])

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model OpportunityProfile {
  id                   String   @id @default(cuid())
  dealId               String   @unique
  deal                 Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // Aggregated intel from all stages
  companyIntel         Json?
  discoveryData        Json?
  qualificationData    Json?
  proposalData         Json?

  // Buyer intent signals (Wave 22 Intelligence Layer)
  buyerIntentScore     Int?
  buyerIntentBreakdown Json?
  suggestedStakeholders Json?
  technologyClues      Json?

  // Stage completion dates
  prospectingCompletedAt   DateTime?
  qualificationCompletedAt DateTime?
  solutioningCompletedAt   DateTime?
  proposalCompletedAt      DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Proposal {
  id               String   @id @default(cuid())
  dealId           String
  deal             Deal     @relation(fields: [dealId], references: [id])
  referenceNumber  String
  clientName       String
  clientContact    String?
  clientEmail      String?
  agentCount       Int      @default(30)
  deploymentPref   String   @default("SaaS")
  exchangeRate     Float    @default(17.0)
  sections         Json
  status           String   @default("draft")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
