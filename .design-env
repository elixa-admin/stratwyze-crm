# Stratwyze Design Environment Variables
# Reference: DESIGN_INSPIRATION_SOURCES.md, DESIGN_SYSTEM.md

# Design Component Libraries
DESIGN_COMPONENT_LIBRARY_PRIMARY=shadcn-ui
DESIGN_COMPONENT_LIBRARY_SECONDARY=aceternity-ui
DESIGN_ANIMATION_LIBRARY=framer-motion

# Design Reference Resources
DESIGN_DASHBOARD_INSPIRATION=tremor-so
DESIGN_SAAS_REFERENCE=saasui-design
DESIGN_SPA_REFERENCE=saaui-design
DESIGN_INTERACTION_REFERENCE=pageflows
DESIGN_MOBILE_REFERENCE=mobbin
DESIGN_TREND_WATCH=recent-design
DESIGN_LANDING_REFERENCE=lapa-ninja
DESIGN_GALLERY_REFERENCES=awwwards,siteinspire,land-book
DESIGN_FIGMA_COMMUNITY=https://www.figma.com/community

# Color Palette
DESIGN_COLOR_PRIMARY=#2563EB
DESIGN_COLOR_PRIMARY_DARK=#1E40AF
DESIGN_COLOR_PRIMARY_LIGHT=#DBEAFE
DESIGN_COLOR_SUCCESS=#10B981
DESIGN_COLOR_WARNING=#F59E0B
DESIGN_COLOR_DANGER=#EF4444
DESIGN_COLOR_INFO=#6366F1

# Typography
DESIGN_FONT_PRIMARY=Inter
DESIGN_FONT_MONO=Jetbrains Mono
DESIGN_FONT_BASE_SIZE=14px

# Spacing
DESIGN_SPACING_BASE=8px
DESIGN_SPACING_UNIT_MULTIPLIER=1

# Animation
DESIGN_ANIMATION_DURATION_SHORT=100ms
DESIGN_ANIMATION_DURATION_MEDIUM=150ms
DESIGN_ANIMATION_DURATION_LONG=200ms
DESIGN_ANIMATION_EASING=ease-out

# Accessibility
DESIGN_CONTRAST_RATIO_MIN=4.5:1
DESIGN_FOCUS_RING_COLOR=#2563EB
DESIGN_FOCUS_RING_WIDTH=2px

# Responsive Design
DESIGN_BREAKPOINT_SM=640px
DESIGN_BREAKPOINT_MD=768px
DESIGN_BREAKPOINT_LG=1024px
DESIGN_BREAKPOINT_XL=1280px
DESIGN_MOBILE_FIRST=true

# Design Methodology
DESIGN_SEARCH_METHODOLOGY=COMPONENT_SPECIFIC,DASHBOARD_PATTERNS,SAAS_PATTERNS,INTERACTIONS,VISUAL_INSPIRATION
DESIGN_VERIFICATION_CHECKLIST=true
DESIGN_ACCESSIBILITY_STANDARD=WCAG_AA
